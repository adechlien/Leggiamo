---
const { theme = "text", fg } = Astro.props;

const marginTop = theme === "home" ? "mt-20" : "mt-0";
const color = theme === "home" ? "text-[#d8f7fe]" : "text-white";
---
<footer
  class={`flex flex-col w-full px-6 pt-4 ${marginTop} mb-10 mx-auto
  lg:px-0 lg:max-w-[1100px] justify-between items-center text-center text-base
  border-t-2 border-t-white/40 sm:border-t-0 sm:pt-0 ${color}`}
>
  <span class="text-center font-bold">2023-2026</span>
  <p class="text-center font-medium">
    Desarrollado por
    <a href="https://adechlien.vercel.app" class="font-semibold" target="_blank">
      adechlien
    </a>
  </p>
</footer>
