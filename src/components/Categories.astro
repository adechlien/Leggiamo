---
import { getCollection } from "astro:content";

const categories = [
  { name: "Consciencia colménica", slug: "consciencia" },
  { name: "Pintas Heredadas", slug: "pintas" },
  { name: "Lágrimas de Siddartha", slug: "lagrimas" },
  { name: "Still Prefer Sentir", slug: "still" },
  { name: "Placebo Onírico", slug: "placebo" },
  { name: "En las luces de colores", slug: "colores" },
];

// Trae todos los textos y arma un mapa { [type]: count }
const posts = await getCollection("texts");
const countsByType = posts.reduce<Record<string, number>>((acc, p) => {
  const t = p.data.type;
  if (!t) return acc;
  acc[t] = (acc[t] ?? 0) + 1;
  return acc;
}, {});
---

<div class="flex flex-col">
  <h3 class="text-4xl font-medium text-left font-bebas text-[#d8f7fe]">Colecciones</h3>

  <div class="flex flex-col sm:flex-row w-full justify-around gap-3 sm:gap-0 border-2 rounded sm:rounded-none sm:border-y-2 sm:border-x-0 border-white/40 sm:mx-0 p-4 sm:py-4 sm:px-0">
    {categories.map((category) => {
      const count = countsByType[category.slug] ?? 0;

      return (
        <a href={`/${category.slug}`} class="">
          <article class="overflow-hidden flex flex-row items-center justify-between gap-2 w-full">
            <h2 class="font-bebas font-normal text-xl text-center text-[#d8f7fe]">
              {category.name}
            </h2>

            <span class="sm:hidden inline-flex items-center justify-center text-sm font-bold px-2 py-0.5 rounded-full text-[#d8f7fe]">
              ({count})
            </span>
          </article>
        </a>
      );
    })}
  </div>
</div>
