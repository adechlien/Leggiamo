---
import { getCollection } from "astro:content";

const posts = await getCollection("texts");
const featured = posts.filter((p: any) => p.data.featured === true);
const sorted = posts.sort(
  (a: any, b: any) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featuredPosts = (featured.length ? featured : sorted)
  .sort(
    (a: any, b: any) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  )
  .slice(0, 6);


const mapType = (type = "") => {
  if (type === "consciencia") return "Consciencia colménica";
  if (type === "lagrimas") return "Lágrimas de Siddartha";
  if (type === "colores") return "En las luces de colores";
  if (type === "still") return "Still Prefer Sentir";
  if (type === "placebo") return "Placebo Onírico";
  if (type === "pintas") return "Pintas Heredadas";
  return type;
};
---

<section class="w-full flex flex-col gap-3">
    <h3 class="text-4xl font-medium text-left font-bebas text-[#d8f7fe] border-b-white/40 border-b-2">Destacados</h3>
    <ul class="flex flex-col sm:flex-row gap-3 px-3">
        {featuredPosts.map((post: any) => (
        <li class="w-full">
            <a href={`/${post.data.type}/${post.slug}`} class="block">
                <div class="relative isolate overflow-hidden rounded aspect-[2/3]">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="absolute inset-0 h-full w-full object-cover pointer-events-none select-none"
                    loading="lazy"
                  />

                  <!-- blur overlay -->
                  <div class="absolute inset-0 bg-black/25  [-webkit-backdrop-filter:blur(12px)] [transform:translateZ(0)]"></div>

                  <div class="relative flex h-full flex-col px-3 py-3 min-w-0">
                    <h3 class="text-white font-bebas text-start text-lg leading-none">
                      {post.data.title}
                    </h3>

                    <p class="mt-auto pt-2 text-sm sm:text-xs text-white font-black text-right truncate">
                      {mapType(post.data.type)}
                    </p>
                  </div>
                </div>
            </a>
        </li>
        ))}
    </ul>
</section>
