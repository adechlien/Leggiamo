---
import { getCollection } from "astro:content";

const posts = await getCollection("texts");
const featured = posts.filter((p: any) => p.data.featured === true);
const sorted = posts.sort(
  (a: any, b: any) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featuredPosts = (featured.length ? featured : sorted)
  .sort(
    (a: any, b: any) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  )
  .slice(0, 6);


const mapType = (type = "") => {
  if (type === "consciencia") return "Consciencia colménica";
  if (type === "lagrimas") return "Lágrimas de Siddartha";
  if (type === "colores") return "En las luces de colores";
  if (type === "still") return "Still Prefer Sentir";
  if (type === "placebo") return "Placebo Onírico";
  if (type === "pintas") return "Pintas Heredadas";
  return type;
};
---

<section class="w-full flex flex-col gap-3">
    <h3 class="text-4xl font-medium text-left font-bebas text-white border-b-white/40 border-b-2">Destacados</h3>
    <ul class="flex flex-col sm:flex-row gap-3 px-3">
        {featuredPosts.map((post: any) => (
        <li class="w-full">
            <a href={`/${post.data.type}/${post.slug}`} class="block">
                <div class="relative isolate overflow-hidden rounded-lg aspect-[2/3]">
                    <img src={post.data.heroImage} alt={post.data.title} class="absolute inset-0 h-full w-full object-cover pointer-events-none select-none" loading="lazy"/>
                    <p class="absolute text-[#d8f7fe] text-xs font-black text-left top-0 right-0 bg-[#024350] text-sm px-2 py-1 rounded m-2">{mapType(post.data.type)}</p>
                    <h3 class="absolute text-white font-bebas truncate text-lg sm:text-base leading-none inset-x-0 bottom-0 bg-[#024350] rounded p-2 sm:py-1 m-2">{post.data.title}</h3>
                </div>
            </a>
        </li>
        ))}
    </ul>
</section>
