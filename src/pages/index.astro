---
import Layout from "../layouts/Layout.astro";
import About from "../components/About.astro";
import Recent from "../components/Recent.astro";
import Categories from "../components/Categories.astro";
import Anios from "../components/Anios.astro";
import Destacados from "../components/Destacados.astro";
import Writers from "../components/Writers.astro";
import Albums from "../components/Albums.astro";
import Footer from "../components/Footer.astro";

const baseBg = "#024350";
---

<Layout title="Inicio" description="Blog de textos literarios, prosa y reflexiones personales.">
    <main class="w-full max-w-[1100px] sm:max-w-none" style={`background-color:${baseBg};`}>
        <About />
        <section class="w-full px-6">
            <div class="mx-auto flex flex-col gap-12 sm:max-w-[1100px]">
                <Categories />
                    <Recent />
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_200px] gap-12 sm:gap-8 items-start">
                <Destacados />
                    <Anios />
                </div>
                <Writers />
                <!-- <Albums /> -->
            </div>
        </section>
    </main>
    <Footer theme="home" />
</Layout>
